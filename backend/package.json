{
  "name": "feynman-backend",
  "version": "0.2.58",
  "private": true,
  "description": "GAHI API server (Fastify + MongoDB)",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20.19.0 <26"
  },
  "main": "dist/index.js",
  "scripts": {
    "build": "bash scripts/with-node.sh tsc -p tsconfig.json",
    "dev": "bash scripts/with-node.sh nodemon",
    "start": "bash scripts/with-node.sh node dist/index.js",
    "typecheck": "bash scripts/with-node.sh tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/static": "^8.1.1",
    "@fastify/websocket": "^11.0.2",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "fastify": "^5.2.1",
    "mammoth": "^1.12.0",
    "mongoose": "^8.9.5",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "nodemon": "^3.1.14",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
