# Copy to backend/.env (or repo root .env) and fill in values.

OPENROUTER_API_KEY=
MONGODB_URI=mongodb://127.0.0.1:27017/feynman
PORT=3141
FEYNMAN_MODEL=openrouter/openai/gpt-5.1
# Faster model for research outline generation (defaults to gpt-4o-mini)
# FEYNMAN_FAST_MODEL=openrouter/openai/gpt-4o-mini
AUTH_SECRET=change-me-in-production

# Default admin account (created/updated on backend startup for /admin/login)
# DEFAULT_ADMIN_EMAIL=admin@aula.com
# DEFAULT_ADMIN_PASSWORD=admin123
# DEFAULT_ADMIN_NAME=Admin
# DEFAULT_ADMIN_ENABLED=true

# AlphaXiv paper search (enabled by default; uses public search API)
# ALPHAXIV_ENABLED=true
# ALPHAXIV_API_BASE=https://api.alphaxiv.org
# ALPHAXIV_MCP_URL=https://api.alphaxiv.org/mcp/v1
# Optional: enables MCP fallback search tools when public search returns no results
# ALPHAXIV_API_KEY=

# Optional: when running `next dev` on :3000 with backend on :3141
# NEXT_PUBLIC_FEYNMAN_BACKEND=http://127.0.0.1:3141

# arXiv export API (https://info.arxiv.org/help/api/basics.html)
# ARXIV_API=https://export.arxiv.org/api/query

# Tavily search fallback when AlphaXiv/arXiv return no papers (https://tavily.com)
# TAVILY_ENABLED=true
# TAVILY_API_KEY=
